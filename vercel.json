{
  "version": 2,
  "builds": [
    {
      "src": "api/otp.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.css",
      "use": "@vercel/static"
    },
    {
      "src": "*.js",
      "use": "@vercel/static",
      "config": { "exclude": [ "api/**" ] }
    },
    {
      "src": "*.jpg",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/otp",
      "dest": "/api/otp.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}